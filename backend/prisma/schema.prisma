generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role             String
  campusId         String?
  campus           Campus?  @relation(fields: [campusId], references: [id])
  status           String   @default("PENDING")
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime @default(now())
  mentorAssignments MentorAssignment[]
  studentAssignments StudentAssignment[]
  messagesSent       Message[]
  meetingInvites     MeetingInvite[]
  documentsUploaded  Document[]
}

model Project {
  id              String       @id @default(uuid())
  company         String
  logoUrl         String
  title           String
  description     String
  budget          String
  duration        String
  status          String       @default("Proposed")
  assignedTo      String?
  targetCampusId  String?
  proposedDueDate String?
  assignedKey     String?
  dateAdded       String
  initialWorkstream String?
  allocations     Allocation[]
  documents       Document[]
}

model Allocation {
  id              String   @id @default(uuid())
  targetCampusId  String
  status          String
  assignedTo      String
  proposedDueDate String
  jiraEpicKey     String?
  
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  mentorAssignments MentorAssignment[]
  teams              Team[]
  messages           Message[]
  meetings           Meeting[]
  documents          Document[]
}

model MentorAssignment {
  id           String     @id @default(uuid())
  allocationId String
  allocation   Allocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)
  facultyId    String
  faculty      User       @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  assignedAt   DateTime   @default(now())
}

model Campus {
  id           String       @id @default(uuid())
  name         String
  jiraBoardKey String?
  isActive     Boolean      @default(true)
  joinedDate   DateTime     @default(now())
  users        User[]
  meetings     Meeting[]
}

model Company {
  id           String    @id @default(uuid())
  name         String    @unique
  logoUrl      String?
  industry     String?
  contactEmail String?
}

model Meeting {
  id          String   @id @default(uuid())
  title       String
  agenda      String?
  scheduledAt DateTime
  meetingLink String?
  status      String   @default("Scheduled")
  campusId    String
  campus      Campus   @relation(fields: [campusId], references: [id], onDelete: Cascade)
  
  allocationId String?
  allocation   Allocation? @relation(fields: [allocationId], references: [id], onDelete: Cascade)
  organizerId  String?
  invites      MeetingInvite[]
}

model AuditLog {
  id              String   @id @default(uuid())
  moderatorId     String
  actionPerformed String
  targetEntity    String?
  details         String?
  timestamp       DateTime @default(now())
}

model Team {
  id           String     @id @default(uuid())
  name         String
  allocationId String
  allocation   Allocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)
  studentAssignments StudentAssignment[]
  createdAt    DateTime   @default(now())
}

model StudentAssignment {
  id           String     @id @default(uuid())
  teamId       String
  team         Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  studentId    String
  student      User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  assignedAt   DateTime   @default(now())
}

model Message {
  id           String     @id @default(uuid())
  content      String
  senderId     String
  sender       User       @relation(fields: [senderId], references: [id], onDelete: Cascade)
  allocationId String
  allocation   Allocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
}

model MeetingInvite {
  id        String   @id @default(uuid())
  meetingId String
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitedBy String?
  status    String   @default("Pending")
  createdAt DateTime @default(now())
}

model Document {
  id           String     @id @default(uuid())
  filename     String
  filepath     String
  fileType     String
  status       String     @default("Pending Review")
  feedback     String?
  
  uploadedById String
  uploadedBy   User       @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  
  allocationId String?
  allocation   Allocation? @relation(fields: [allocationId], references: [id], onDelete: Cascade)
  
  projectId    String?
  project      Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

